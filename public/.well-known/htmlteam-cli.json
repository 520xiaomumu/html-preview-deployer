{
  "name": "htmlteam",
  "version": "0.1.0",
  "description": "Agent-native HTML deployment CLI and API.",
  "auth": {
    "type": "bearer",
    "env": "HTMLTEAM_API_KEY"
  },
  "commands": [
    {
      "name": "deploy",
      "description": "Deploy an HTML file or stdin content.",
      "args": ["file"],
      "flags": ["--stdin", "--filename", "--title", "--code", "--visibility", "--json"],
      "endpoint": "POST /api/deploy",
      "output": "DeployResult"
    },
    {
      "name": "list",
      "description": "List owned deployments.",
      "flags": ["--status", "--q", "--json"],
      "output": "ApiSuccess<DeploymentList>"
    },
    {
      "name": "get",
      "description": "Read deployment metadata by id or code.",
      "args": ["id-or-code"],
      "flags": ["--json"],
      "output": "ApiSuccess<Deployment>"
    },
    {
      "name": "content",
      "description": "Read HTML content by id or code.",
      "args": ["id-or-code"],
      "flags": ["--output", "--json"],
      "endpoint": "GET /api/deploy/content?code=:code",
      "output": "ContentResult"
    },
    {
      "name": "update",
      "description": "Replace deployment HTML content.",
      "args": ["id-or-code", "file"],
      "flags": ["--filename", "--title", "--json"],
      "endpoint": "PATCH /api/deploy/content",
      "output": "DeployResult"
    },
    {
      "name": "enable",
      "description": "Activate a deployment.",
      "args": ["id-or-code"],
      "flags": ["--json"],
      "output": "ApiSuccess<Deployment>"
    },
    {
      "name": "disable",
      "description": "Deactivate a deployment.",
      "args": ["id-or-code"],
      "flags": ["--json"],
      "output": "ApiSuccess<Deployment>"
    },
    {
      "name": "delete",
      "description": "Delete a deployment and its stored files.",
      "args": ["id-or-code"],
      "flags": ["--yes", "--json"],
      "output": "ApiSuccess<{deleted:boolean,id:string}>"
    }
  ]
}
